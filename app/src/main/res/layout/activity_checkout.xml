<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_checkout_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pembayaran"
        android:textColor="@color/primary_green"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_order_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_checkout_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:id="@+id/iv_checkout_menu"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:scaleType="centerCrop"
                android:src="@drawable/kopsu"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_summary_menu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Menu: -"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_summary_details"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Detail: -" />

                <TextView
                    android:id="@+id/tv_summary_table"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Meja: -" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_payment_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Pilih Metode Pembayaran"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/cv_order_summary"
        app:layout_constraintStart_toStartOf="parent" />

    <RadioGroup
        android:id="@+id/rg_payment_method"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_payment_label">

        <RadioButton
            android:id="@+id/rb_qris"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="QRIS"
            android:drawableStart="@drawable/qrcode"
            android:drawablePadding="16dp"
            android:checked="true"
            android:gravity="center_vertical" />

        <RadioButton
            android:id="@+id/rb_transfer"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Transfer Bank"
            android:drawableStart="@drawable/banks"
            android:drawablePadding="16dp"
            android:gravity="center_vertical" />

        <!-- Sub-selection for Bank (Initially Hidden) -->
        <RadioGroup
            android:id="@+id/rg_bank_selection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:visibility="gone">

            <RadioButton
                android:id="@+id/rb_bank_bni"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Bank BNI"
                android:drawableStart="@drawable/arcticons__bni_mobile_banking__1_"
                android:drawablePadding="12dp"
                android:gravity="center_vertical" />
        </RadioGroup>

        <RadioButton
            android:id="@+id/rb_cashier"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Bayar di Kasir"
            android:drawableStart="@drawable/cash"
            android:drawablePadding="16dp"
            android:gravity="center_vertical" />
    </RadioGroup>

    <Button
        android:id="@+id/btn_pay_now"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="@color/primary_green"
        android:text="Bayar Sekarang"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Overlay Loading -->
    <FrameLayout
        android:id="@+id/fl_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CCFFFFFF"
        android:visibility="gone"
        android:elevation="20dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="@color/primary_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Memproses Pembayaran..."
                android:textColor="@color/primary_green"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>